# =============================================================================
# Resolve MDM Copilot — Environment Variables Template
# =============================================================================
# 1. Copy this file to a new file named `.env` (in the same folder)
# 2. Fill in your actual values
# 3. NEVER commit .env to git — it's in .gitignore for a reason
# 4. Keep .env.example up to date when you add new vars (this file IS committed)
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — DB + pgvector (NEEDED FROM DAY 2)
# -----------------------------------------------------------------------------
# Where to find these:
#   Supabase dashboard → your project → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# Database connection string (used by psycopg2, SQLAlchemy, dbt, etc.)
# Where to find it:
#   Supabase dashboard → click "Connect" button at top → "Session pooler" tab
# Replace [YOUR-PASSWORD] with the DB password you set when creating the project
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres


# -----------------------------------------------------------------------------
# Voyage AI — embeddings (NEEDED FROM DAY 9)
# -----------------------------------------------------------------------------
# Where to find:
#   voyageai.com → Dashboard → API Keys → Create new secret key
# Free tier: 50M tokens/month, no card required
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default embedding model for this project
VOYAGE_EMBEDDING_MODEL=voyage-3-lite


# -----------------------------------------------------------------------------
# LangSmith — observability (NEEDED FROM WEEK 3)
# -----------------------------------------------------------------------------
# Where to find:
#   smith.langchain.com → Settings → API Keys → Create API Key
# Free tier: 5K traces/month
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=resolve-mdm-copilot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# -----------------------------------------------------------------------------
# Anthropic API — runtime LLM calls from your app (NEEDED FROM WEEK 3)
# -----------------------------------------------------------------------------
# DO NOT sign up on Day 1. Defer until Week 3 when match rationale chain begins.
# Where to find (when ready):
#   console.anthropic.com → Settings → API Keys → Create Key
# Note: this is for your APP's runtime calls, NOT for Claude in Cursor/VS Code
#   (those use your existing subscription, no API key needed)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default Claude model for runtime LLM calls
ANTHROPIC_MODEL=claude-sonnet-4-5


# -----------------------------------------------------------------------------
# Project-level settings (no secrets, but keeps config in one place)
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
