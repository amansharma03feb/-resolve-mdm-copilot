# =============================================================================
# .gitignore — Resolve MDM Copilot
# =============================================================================

# -----------------------------------------------------------------------------
# CRITICAL: Environment files (never commit secrets)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
!.env.example


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Testing & type checking
.pytest_cache/
.mypy_cache/
.dmypy.json
.coverage
htmlcov/
.tox/


# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/


# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini


# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
# Don't commit large data files
data/raw/*.csv
data/raw/*.json
data/processed/*.csv
data/processed/*.parquet
!data/raw/.gitkeep
!data/processed/.gitkeep

# Logs
*.log
logs/

# LangSmith / LangChain
.langsmith/
.langchain/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Streamlit
.streamlit/secrets.toml

# Local DB dumps
*.dump
*.sql.gz

# Output / temp
tmp/
temp/
output/
